# Paperclip connection (required)
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=your-board-api-key-here
PAPERCLIP_COMPANY_ID=your-company-id-here

# ATLAS auth (required)
ATLAS_ADMIN_PASSWORD=your-admin-password
ATLAS_AUTH_SECRET=random-32-byte-hex-for-sessions

# Optional
CACHE_TTL_SECONDS=300
